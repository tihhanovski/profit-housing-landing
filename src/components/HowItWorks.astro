---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
const steps = [1, 2, 3];
---

<section id="how" class="section">
  <div class="container-shell card p-8 md:p-10">
    <h2 class="font-display text-3xl md:text-4xl">{t('how.title')}</h2>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {
        steps.map((step) => (
          <article class="rounded-xl border border-[var(--line)] bg-white p-5">
            <p class="text-xs uppercase text-[var(--muted)]">Step {step}</p>
            <h3 class="mt-2 font-display text-xl">{t(`how.${step}.title`)}</h3>
            <p class="mt-2 text-sm text-[var(--muted)]">{t(`how.${step}.desc`)}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
