---
import DefaultContact from './DefaultContact.astro';
import MauticContact from './MauticContact.astro';

interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
const mauticFormId = import.meta.env.PUBLIC_MAUTIC_FORM_ID ?? '1';
const mauticFormName = import.meta.env.PUBLIC_MAUTIC_FORM_NAME ?? 'profit24-housing-contact';
const endpoint = 'https://mautic.intellisoft.ee/form/submit';
---

<section id="contact" class="section">
  <div class="container-shell card overflow-hidden md:grid md:grid-cols-5">
    <div class="bg-gradient-to-br from-[#0f8a70] to-[#1f6f8b] p-8 text-white md:col-span-2">
      <h2 class="font-display text-3xl">{t('contact.title')}</h2>
      <p class="mt-3 text-white/90">{t('contact.subtitle')}</p>
      <p class="mt-4 text-sm text-white/75">
        Mautic: mautic.intellisoft.ee
      </p>
    </div>

    <!-- <DefaultContact t={t} /> -->
    <div class="p-8 md:col-span-3">
      <MauticContact t={t} />
    </div>


  </div>
</section>

