<div id="mauticform_wrapper_profit24housingcontact" class="mauticform_wrapper">
    <form
        autocomplete="false"
        role="form"
        method="post"
        action="https://mautic.intellisoft.ee/form/submit?formId=6"
        id="mauticform_profit24housingcontact"
        data-mautic-form="profit24housingcontact"
        enctype="multipart/form-data"
    >
        <div
            class="mauticform-error"
            id="mauticform_profit24housingcontact_error"
        >
        </div>
        <div
            class="mauticform-message"
            id="mauticform_profit24housingcontact_message"
        >
        </div><div class="mauticform-innerform">
            <div
                class="mauticform-page-wrapper mauticform-page-1"
                data-mautic-form-page="1"
            >
                <div
                    id="mauticform_profit24housingcontact_nimi"
                    class="mauticform-row mauticform-text mauticform-field-1 mauticform-required"
                    data-validate="nimi"
                    data-validation-type="text"
                >
                    <label
                        id="mauticform_label_profit24housingcontact_nimi"
                        for="mauticform_input_profit24housingcontact_nimi"
                        class="mauticform-label">Nimi</label
                    >

                    <input
                        type="text"
                        name="mauticform[nimi]"
                        value=""
                        id="mauticform_input_profit24housingcontact_nimi"
                        class="mauticform-input"
                    />

                    <span class="mauticform-errormsg" style="display:none;"
                        >name expected</span
                    >
                </div>

                <div
                    id="mauticform_profit24housingcontact_email"
                    class="mauticform-row mauticform-email mauticform-field-2 mauticform-required"
                    data-validate="email"
                    data-validation-type="email"
                >
                    <label
                        id="mauticform_label_profit24housingcontact_email"
                        for="mauticform_input_profit24housingcontact_email"
                        class="mauticform-label">E-mail</label
                    >

                    <input
                        type="email"
                        name="mauticform[email]"
                        value=""
                        id="mauticform_input_profit24housingcontact_email"
                        class="mauticform-input"
                    />

                    <span class="mauticform-errormsg" style="display:none;"
                        >This is required.</span
                    >
                </div>

                <div
                    id="mauticform_profit24housingcontact_f_message"
                    class="mauticform-row mauticform-text mauticform-field-3"
                >
                    <label
                        id="mauticform_label_profit24housingcontact_f_message"
                        for="mauticform_input_profit24housingcontact_f_message"
                        class="mauticform-label">Message</label
                    >

                    <textarea
                        name="mauticform[f_message]"
                        id="mauticform_input_profit24housingcontact_f_message"
                        class="mauticform-textarea"></textarea>

                    <span class="mauticform-errormsg" style="display:none;"
                    ></span>
                </div>

                <div
                    id="mauticform_profit24housingcontact_submit"
                    class="mauticform-row mauticform-button-wrapper mauticform-field-4"
                >
                    <button
                        class="btn btn-ghost mauticform-button"
                        name="mauticform[submit]"
                        value="1"
                        id="mauticform_input_profit24housingcontact_submit"
                        type="submit">Submit</button
                    >
                </div>
            </div>
        </div><input
            type="hidden"
            name="mauticform[formId]"
            id="mauticform_profit24housingcontact_id"
            value="6"
        />
        <input
            type="hidden"
            name="mauticform[return]"
            id="mauticform_profit24housingcontact_return"
            value=""
        />
        <input
            type="hidden"
            name="mauticform[formName]"
            id="mauticform_profit24housingcontact_name"
            value="profit24housingcontact"
        />
    </form>
</div>
