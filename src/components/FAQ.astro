---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
const items = [1, 2, 3];
---

<section id="faq" class="section">
  <div class="container-shell">
    <h2 class="font-display text-3xl md:text-4xl">{t('faq.title')}</h2>
    <div class="mt-8 space-y-3">
      {
        items.map((n) => (
          <details class="card p-5">
            <summary class="cursor-pointer list-none pr-8 font-semibold">{t(`faq.${n}.q`)}</summary>
            <p class="mt-3 text-sm text-[var(--muted)]">{t(`faq.${n}.a`)}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
