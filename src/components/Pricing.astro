---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
---

<section id="pricing" class="section">
  <div class="container-shell">
    <h2 class="font-display text-3xl md:text-4xl">{t("pricing.title")}</h2>
  </div>
  <div class="container-shell card p-8 md:p-10 mt-8">
    <p
      class="text-2xl font-semibold leading-relaxed text-[var(--ink)] md:text-3xl"
    >
      {t("pricing.price")}
    </p>
    <p>{t("pricing.unit")}</p>

      <p class="font-semibold text-[var(--ink)] mt-8">{t("pricing.notice.free")}</p>
      <p class="mt-4">{t("pricing.notice.ai_features")}</p>
      <p class="mt-4">{t("pricing.notice.special")}</p>
      <p class="mt-4">{t("pricing.notice.vat")}</p>
  </div>
</section>
