---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;

const plans = [
  {
    key: 'basic',
    featured: false
  },
  {
    key: 'pro',
    featured: true
  },
  {
    key: 'enterprise',
    featured: false
  }
];
---

<section id="pricing" class="section">
  <div class="container-shell">
    <h2 class="font-display text-3xl md:text-4xl">{t('pricing.title')}</h2>
    <p class="mt-3 max-w-2xl text-[var(--muted)]">{t('pricing.subtitle')}</p>
    <div class="mt-4 space-y-1 rounded-2xl border border-[var(--line)] bg-white p-4 text-sm text-[var(--ink)]">
      <p class="font-semibold">{t('pricing.notice.free')}</p>
      <p>{t('pricing.notice.special')}</p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {
        plans.map((plan) => (
          <article class={`card p-6 ${plan.featured ? 'relative border-[#1f6f8b] bg-[#f0f8fc]' : ''}`}>
            {plan.featured && (
              <span class="absolute right-4 top-4 rounded-full bg-[#1f6f8b] px-3 py-1 text-xs font-semibold text-white">
                Popular
              </span>
            )}
            <h3 class="font-display text-2xl">{t(`pricing.${plan.key}.name`)}</h3>
            <p class="mt-2 text-2xl font-semibold">{t(`pricing.${plan.key}.price`)}</p>
            <ul class="mt-4 space-y-2 text-sm text-[var(--muted)]">
              <li>- {t(`pricing.${plan.key}.feature1`)}</li>
              <li>- {t(`pricing.${plan.key}.feature2`)}</li>
              <li>- {t(`pricing.${plan.key}.feature3`)}</li>
            </ul>
            <a href="#contact" class="btn-primary mt-6 w-full">{t('hero.ctaSecondary')}</a>
          </article>
        ))
      }
    </div>
  </div>
</section>
