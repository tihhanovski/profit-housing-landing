---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
const items = [1, 2, 3, 4, 5, 6];
---

<section id="features" class="section">
  <div class="container-shell">
    <h2 class="font-display text-3xl md:text-4xl">{t('features.title')}</h2>
    <p class="mt-3 max-w-2xl text-[var(--muted)]">{t('features.subtitle')}</p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map((n) => (
          <article class="card reveal p-5">
            <p class="mb-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-[#e8f4ef] text-sm font-semibold text-[var(--accent)]">
              {n}
            </p>
            <h3 class="font-display text-xl">{t(`features.${n}.title`)}</h3>
            <p class="mt-2 text-sm text-[var(--muted)]">{t(`features.${n}.desc`)}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
