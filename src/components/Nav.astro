---
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  t: (key: string) => string;
}

const { locale, t } = Astro.props;

const localeLinks: Record<Locale, string> = {
  et: '/',
  en: '/en/',
  ru: '/ru/'
};

const anchor = (path: string) => `${localeLinks[locale]}${path}`;
---

<header class="sticky top-0 z-50 border-b border-[var(--line)] bg-[#f6f7f2de] backdrop-blur">
  <div class="container-shell flex items-center justify-between py-3">
    <a href={localeLinks[locale]} class="font-display text-lg font-semibold tracking-tight">Profit KÜ</a>

    <nav class="hidden items-center gap-6 text-sm md:flex">
      <a href={anchor('#features')}>{t('nav.features')}</a>
      <a href={anchor('#how')}>{t('nav.how')}</a>
      <a href={anchor('#pricing')}>{t('nav.pricing')}</a>
      <a href={anchor('#testimonials')}>{t('nav.testimonials')}</a>
      <a href={anchor('#faq')}>{t('nav.faq')}</a>
      <a href={anchor('#contact')}>{t('nav.contact')}</a>
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a class={`btn-secondary text-xs ${locale === 'et' ? 'bg-white' : ''}`} href="/">
        {t('lang.et')}
      </a>
      <a class={`btn-secondary text-xs ${locale === 'en' ? 'bg-white' : ''}`} href="/en/">
        {t('lang.en')}
      </a>
      <a class={`btn-secondary text-xs ${locale === 'ru' ? 'bg-white' : ''}`} href="/ru/">
        {t('lang.ru')}
      </a>
    </div>

    <details class="group md:hidden">
      <summary
        class="list-none rounded-full border border-[var(--line)] p-2 text-sm"
        aria-label="Open menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </summary>
      <div class="absolute right-4 mt-3 w-56 rounded-xl border border-[var(--line)] bg-white p-4 shadow-lg">
        <div class="flex flex-col gap-3 text-sm">
          <a href={anchor('#features')}>{t('nav.features')}</a>
          <a href={anchor('#how')}>{t('nav.how')}</a>
          <a href={anchor('#pricing')}>{t('nav.pricing')}</a>
          <a href={anchor('#testimonials')}>{t('nav.testimonials')}</a>
          <a href={anchor('#faq')}>{t('nav.faq')}</a>
          <a href={anchor('#contact')}>{t('nav.contact')}</a>
        </div>
        <div class="mt-4 flex gap-2 border-t border-[var(--line)] pt-3">
          <a class="btn-secondary text-xs" href="/">{t('lang.et')}</a>
          <a class="btn-secondary text-xs" href="/en/">{t('lang.en')}</a>
          <a class="btn-secondary text-xs" href="/ru/">{t('lang.ru')}</a>
        </div>
      </div>
    </details>
  </div>
</header>
