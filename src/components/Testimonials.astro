---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
const items = [1, 2, 3];
---

<section id="testimonials" class="section">
  <div class="container-shell">
    <h2 class="font-display text-3xl md:text-4xl">{t('testimonials.title')}</h2>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {
        items.map((n) => (
          <blockquote class="card p-6">
            <p class="text-lg leading-relaxed">"{t(`testimonials.${n}.quote`)}"</p>
            <footer class="mt-4 text-sm font-medium text-[var(--muted)]">{t(`testimonials.${n}.author`)}</footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
