---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;

const slides = [
  {
    src: '/hero/slide-1.svg',
    alt: 'Dashboard overview with payments and occupancy metrics',
    caption: 'Daily overview'
  },
  {
    src: '/hero/slide-2.svg',
    alt: 'Resident portal with service request timeline',
    caption: 'Resident portal'
  },
  {
    src: '/hero/slide-3.svg',
    alt: 'Board workflow view with approvals and reminders',
    caption: 'Board workflow'
  }
];
---

<section class="section">
  <div class="container-shell grid items-center gap-8 md:grid-cols-2">
    <div class="reveal">
      <p class="mb-4 inline-block rounded-full border border-[var(--line)] bg-white px-4 py-1 text-sm text-[var(--muted)]">
        {t('hero.badge')}
      </p>
      <h1 class="font-display text-4xl leading-tight md:text-5xl">{t('hero.title')}</h1>
      <p class="mt-4 max-w-xl text-[var(--muted)]">{t('hero.subtitle')}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#contact" class="btn-primary">{t('hero.ctaPrimary')}</a>
        <a href="#how" class="btn-secondary">{t('hero.ctaSecondary')}</a>
      </div>
      <p class="mt-6 text-sm text-[var(--muted)]">{t('hero.trust')}</p>
    </div>

    <div class="reveal delay-1 hero-carousel" data-hero-carousel aria-label="Product image carousel">
      <div class="hero-carousel-track" data-track>
        {
          slides.map((slide, index) => (
            <figure class="hero-slide" data-slide>
              <img
                src={slide.src}
                alt={slide.alt}
                loading={index === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="hero-slide-image"
              />
              <figcaption class="hero-slide-caption">{slide.caption}</figcaption>
            </figure>
          ))
        }
      </div>

      <div class="hero-carousel-controls" aria-label="Carousel controls">
        <button type="button" class="hero-carousel-btn" data-prev aria-label="Previous image">
          <span aria-hidden="true">&#8592;</span>
        </button>
        <div class="hero-carousel-dots" role="tablist" aria-label="Slide picker">
          {
            slides.map((slide, index) => (
              <button
                type="button"
                class="hero-carousel-dot"
                data-dot
                data-index={index}
                aria-label={`Show slide ${index + 1}: ${slide.caption}`}
              ></button>
            ))
          }
        </div>
        <button type="button" class="hero-carousel-btn" data-next aria-label="Next image">
          <span aria-hidden="true">&#8594;</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const carousels = document.querySelectorAll('[data-hero-carousel]');

  for (const carousel of carousels) {
    if (!(carousel instanceof HTMLElement)) {
      continue;
    }

    const track = carousel.querySelector('[data-track]');
    const slides = carousel.querySelectorAll('[data-slide]');
    const dots = carousel.querySelectorAll('[data-dot]');
    const prev = carousel.querySelector('[data-prev]');
    const next = carousel.querySelector('[data-next]');

    if (!(track instanceof HTMLElement) || slides.length < 2) {
      continue;
    }

    let active = 0;
    let timer: ReturnType<typeof window.setInterval> | undefined;
    const autoplayMs = 4200;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let pointerId: number | null = null;
    let startX = 0;
    let deltaX = 0;
    let isDragging = false;
    const swipeThreshold = 48;

    const render = () => {
      track.style.transform = `translateX(-${active * 100}%)`;

      dots.forEach((dot, index) => {
        if (!(dot instanceof HTMLButtonElement)) {
          return;
        }

        const isActive = index === active;
        dot.setAttribute('aria-current', isActive ? 'true' : 'false');
        dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
    };

    const stopAuto = () => {
      if (timer) {
        window.clearInterval(timer);
        timer = undefined;
      }
    };

    const startAuto = () => {
      if (reducedMotion) {
        return;
      }

      stopAuto();
      timer = window.setInterval(() => {
        active = (active + 1) % slides.length;
        render();
      }, autoplayMs);
    };

    const moveTo = (index: number) => {
      active = (index + slides.length) % slides.length;
      render();
      startAuto();
    };

    const pointerDown = (event: PointerEvent) => {
      if (event.pointerType === 'mouse') {
        return;
      }

      pointerId = event.pointerId;
      startX = event.clientX;
      deltaX = 0;
      isDragging = true;
      stopAuto();

      track.style.transition = 'none';
      track.setPointerCapture(pointerId);
    };

    const pointerMove = (event: PointerEvent) => {
      if (!isDragging || pointerId !== event.pointerId) {
        return;
      }

      deltaX = event.clientX - startX;
      const offset = -(active * 100) + (deltaX / track.clientWidth) * 100;
      track.style.transform = `translateX(${offset}%)`;
    };

    const pointerUp = (event: PointerEvent) => {
      if (!isDragging || pointerId !== event.pointerId) {
        return;
      }

      isDragging = false;
      pointerId = null;

      track.style.transition = '';
      track.releasePointerCapture(event.pointerId);

      if (Math.abs(deltaX) > swipeThreshold) {
        moveTo(active + (deltaX < 0 ? 1 : -1));
        return;
      }

      render();
      startAuto();
    };

    prev?.addEventListener('click', () => moveTo(active - 1));
    next?.addEventListener('click', () => moveTo(active + 1));

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => moveTo(index));
    });

    carousel.addEventListener('mouseenter', stopAuto);
    carousel.addEventListener('mouseleave', startAuto);
    carousel.addEventListener('focusin', stopAuto);
    carousel.addEventListener('focusout', startAuto);
    track.addEventListener('pointerdown', pointerDown);
    track.addEventListener('pointermove', pointerMove);
    track.addEventListener('pointerup', pointerUp);
    track.addEventListener('pointercancel', pointerUp);
    carousel.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) {
        return;
      }

      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        moveTo(active - 1);
      }

      if (event.key === 'ArrowRight') {
        event.preventDefault();
        moveTo(active + 1);
      }
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAuto();
        return;
      }

      startAuto();
    });

    render();
    startAuto();
  }
</script>
